<scenario>
  <!-- At 500s: one FTTH host starts a single huge file transfer (elephant flow) -->
  <at t="500">
    <set-param module="isp_ftth0.ftth.host[0].app[2]"
               par="replyLength" value="500000000B" />
    <set-param module="isp_ftth0.ftth.host[0].app[2]"
               par="idleInterval" value="0.1s" />
  </at>
  <!-- At 800s: transfer ends, restore -->
  <at t="800">
    <set-param module="isp_ftth0.ftth.host[0].app[2]"
               par="replyLength" value="1B*int(truncnormal(15000000,3000000))" />
    <set-param module="isp_ftth0.ftth.host[0].app[2]"
               par="idleInterval" value="exponential(180s)" />
  </at>
</scenario>